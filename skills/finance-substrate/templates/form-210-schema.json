{
  "form": "210",
  "description": "Declaracion de Renta y Complementario Personas Naturales y Asimiladas",
  "wizard_steps": 15,
  "navigation": {
    "step_selector": "document.querySelectorAll('.step-counter')[N].click()",
    "next_button": "Siguiente",
    "note": "Field refs (data-ref) change between sessions — always snapshot before interacting"
  },
  "steps": [
    {
      "step": 1,
      "title": "Datos del Declarante",
      "description": "Pre-filled from RUT. Only gender and economic activity need filling.",
      "casillas": [
        {
          "casilla": 286,
          "label": "Genero",
          "field_type": "combobox",
          "editable": true,
          "options": ["1 - Femenino", "2 - Masculino"],
          "data_source": null,
          "et_article": null,
          "note": "Select from combobox. Not mapped to tax projection."
        },
        {
          "casilla": 24,
          "label": "Actividad economica principal",
          "field_type": "combobox",
          "editable": true,
          "options": "CIIU codes — select matching code from RUT",
          "data_source": null,
          "et_article": null,
          "note": "CIIU code must match RUT registration."
        }
      ]
    },
    {
      "step": 2,
      "title": "Deduccion Imputable sin limitantes",
      "description": "E-invoice deduction and additional yes/no questions.",
      "casillas": [
        {
          "casilla": 299,
          "label": "Factura electronica de venta como soporte de costos y deducciones",
          "field_type": "radio",
          "editable": true,
          "options": ["Si", "No"],
          "data_source": "einvoices.count > 0 ? 'Si' : 'No'",
          "et_article": "Art. 336 Num. 5, Ley 2277/2022",
          "note": "Select Si if claiming e-invoice 1% deduction."
        },
        {
          "casilla": 297,
          "label": "Valor compras con factura electronica",
          "field_type": "textbox",
          "editable": true,
          "data_source": "einvoices.total_facturado",
          "et_article": "Art. 336 Num. 5, Ley 2277/2022",
          "note": "Total value of purchases supported by e-invoices."
        },
        {
          "casilla": 28,
          "label": "Deduccion 1% factura electronica",
          "field_type": "textbox",
          "editable": false,
          "data_source": null,
          "et_article": "Art. 336 Num. 5, Ley 2277/2022",
          "note": "Auto-calculated as 1% of casilla 297. Disabled field."
        },
        {
          "casilla": 245,
          "label": "Victima del conflicto armado",
          "field_type": "radio",
          "editable": true,
          "options": ["Si", "No"],
          "data_source": "default: 'No'",
          "et_article": null,
          "note": "Default No for most filers."
        },
        {
          "casilla": 247,
          "label": "Beneficiario convenio doble tributacion",
          "field_type": "radio",
          "editable": true,
          "options": ["Si", "No"],
          "data_source": "default: 'No'",
          "et_article": null,
          "note": "Default No unless claiming treaty benefits."
        },
        {
          "casilla": 249,
          "label": "Residente fiscal en Colombia",
          "field_type": "radio",
          "editable": true,
          "options": ["Si", "No"],
          "data_source": "default: 'No'",
          "et_article": "Art. 10 ET",
          "note": "Default No — pre-filled question."
        },
        {
          "casilla": 251,
          "label": "Obligado a llevar contabilidad",
          "field_type": "radio",
          "editable": true,
          "options": ["Si", "No"],
          "data_source": "default: 'No'",
          "et_article": null,
          "note": "Default No for persona natural not obligated."
        }
      ]
    },
    {
