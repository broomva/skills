# TradingView Bridge environment variables. Copy to .env (gitignored).

# REQUIRED. Service exits 1 at startup if not "paper".
TVBRIDGE_TRADING_MODE=paper

# REQUIRED. Shared secret Pine Script alerts must include in body.secret.
# Generate with: openssl rand -hex 32
TVBRIDGE_TV_WEBHOOK_SECRET=replace-me-with-openssl-rand-hex-32

# OPTIONAL. Broker dispatch mode. Default 'mock' — every alert goes to an
# in-memory MockClient (used by all tests + local dev without broker creds).
# 'real-paper' attempts IBKR TWS paper-port, Kraken sandbox, Polymarket CLOB;
# requires the broker-specific env vars below + `tradingview-bridge[brokers]`.
# TVBRIDGE_BROKER_MODE=mock

# OPTIONAL. SQLite idempotency DB path. Default ~/.tradingview-bridge/idempotency.sqlite.
# TVBRIDGE_DB_PATH=

# OPTIONAL. Comma-separated TradingView webhook source IPs. Verify periodically at
# https://www.tradingview.com/support/solutions/43000529348/
# TVBRIDGE_TV_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# OPTIONAL. Per-IP rate limit (60-second sliding window). Default 60.
# TVBRIDGE_RATE_LIMIT_PER_MINUTE=60

# OPTIONAL. Logging level. Default INFO. DEBUG/INFO/WARNING/ERROR.
# TVBRIDGE_LOG_LEVEL=INFO

# OPTIONAL. Trust X-Forwarded-For for source IP check. Set true behind a
# reverse proxy / Cloudflare Tunnel.
# TVBRIDGE_TRUST_FORWARDED_FOR=false

# OPTIONAL. Override the bookkeeping CLI path. Default tries
# ~/broomva/skills/bookkeeping/scripts/bookkeeping.py then PATH.
# TVBRIDGE_BOOKKEEPING_CLI=

# --- Real-paper broker credentials (only needed when TVBRIDGE_BROKER_MODE=real-paper) ---

# IBKR — paper port is 7497, live port is 7496. Requires TWS/IB Gateway running.
# TVBRIDGE_IBKR_HOST=127.0.0.1
# TVBRIDGE_IBKR_PORT=7497

# Kraken — sandbox keys from https://demo-futures.kraken.com OR main-net read-only keys.
# TVBRIDGE_KRAKEN_API_KEY=
# TVBRIDGE_KRAKEN_API_SECRET=

# Polymarket — eth wallet private key + CLOB host.
# TVBRIDGE_POLYMARKET_WALLET_KEY=
# TVBRIDGE_POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# --- Autonomous operator (`operate`) ---

# OPTIONAL. Order ledger SQLite path (positions). Default ~/.tradingview-bridge/orders.sqlite.
# TVBRIDGE_ORDERS_DB_PATH=

# OPTIONAL. Operator state JSON path. Default ~/.tradingview-bridge/operator-state.json.
# TVBRIDGE_OPERATOR_STATE_PATH=

# OPTIONAL. TVBRIDGE_BROKER_MODE=tradingview-paper drives TradingView's built-in
# Paper Trading simulator via the Interceptor browser CLI (no broker creds; needs
# a logged-in TradingView session + the interceptor extension).
