{
  "name": "gasgo",
  "version": "0.1.0",
  "description": "Best gas deal near me — engine over live Colombian per-station fuel-price open data (SICOM via datos.gov.co Socrata).",
  "type": "module",
  "module": "src/engine.ts",
  "bin": {
    "gasgo": "src/cli.ts"
  },
  "scripts": {
    "gasgo": "bun run src/cli.ts",
